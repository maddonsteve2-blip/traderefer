### 4.2 components/tour/HelpButton.tsx

```tsx
'use client';
import { useNextStep } from 'nextstepjs';

type HelpButtonProps = {
  tourName: 'referrer-main' | 'business-main';
};

export const HelpButton = ({ tourName }: HelpButtonProps) => {
  const { startNextStep } = useNextStep();

  return (
    <button
      onClick={() => startNextStep(tourName)}
      aria-label="Start guided tour"
      title="Take a guided tour"
      style={{
        position: 'fixed',
        bottom: '24px',
        right: '24px',
        zIndex: 9999,
        width: '48px',
        height: '48px',
        borderRadius: '50%',
        background: '#E8620A',
        color: '#FFFFFF',
        border: 'none',
        cursor: 'pointer',
        fontSize: '22px',
        fontWeight: 700,
        boxShadow: '0 4px 16px rgba(232, 98, 10, 0.5)',
        display: 'flex',
        alignItems: 'center',
        justifyContent: 'center',
        transition: 'transform 0.2s ease, box-shadow 0.2s ease',
      }}
      onMouseEnter={(e) => {
        (e.currentTarget as HTMLButtonElement).style.transform = 'scale(1.1)';
        (e.currentTarget as HTMLButtonElement).style.boxShadow = '0 6px 24px rgba(232, 98, 10, 0.7)';
      }}
      onMouseLeave={(e) => {
        (e.currentTarget as HTMLButtonElement).style.transform = 'scale(1)';
        (e.currentTarget as HTMLButtonElement).style.boxShadow = '0 4px 16px rgba(232, 98, 10, 0.5)';
      }}
    >
      ?
    </button>
  );
};
```


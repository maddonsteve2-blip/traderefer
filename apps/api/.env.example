# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname

# ── Clerk Auth ────────────────────────────────
CLERK_SECRET_KEY=sk_live_...

# ── Stripe ────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (Email) ────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM=traderefer.au <no-reply@traderefer.au>

# ── Twilio (SMS) ──────────────────────────────
# Get from: https://console.twilio.com
# Account SID: Twilio Console > Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Auth Token: Twilio Console > Account Info
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# From Number: Twilio Console > Phone Numbers (E.164 format, e.g. +61400000000)
TWILIO_FROM_NUMBER=+61400000000

# ── App URLs ──────────────────────────────────
FRONTEND_URL=https://traderefer.au
